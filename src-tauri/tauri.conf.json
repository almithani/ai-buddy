{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Buddy",
  "version": "0.1.0",
  "identifier": "com.aibuddy.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "onboarding",
        "title": "AI Buddy",
        "width": 420,
        "height": 640,
        "center": true,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": false,
        "decorations": true
      },
      {
        "label": "droid",
        "title": "AI Buddy",
        "width": 100,
        "height": 100,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "shadow": false,
        "acceptFirstMouse": true
      },
      {
        "label": "chat",
        "title": "AI Buddy",
        "width": 360,
        "height": 520,
        "minWidth": 300,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": []
  }
}
